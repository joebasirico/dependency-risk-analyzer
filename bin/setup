#!/usr/bin/env ruby

$LOAD_PATH.unshift(File.expand_path('../lib', __dir__))

require 'dependency_risk/boot'

DependencyRisk::Boot.isolate_gems!

bundle = File.join(RbConfig::CONFIG.fetch('bindir'), 'bundle')
exec bundle, 'install' if File.executable?(bundle)

abort "Unable to find bundle next to #{RbConfig.ruby}"
